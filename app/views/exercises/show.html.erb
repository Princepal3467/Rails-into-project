<div class="detail-box">
  <h1><%= @exercise.name %></h1>

  <p><strong>Category:</strong> <%= link_to @exercise.category.name, category_path(@exercise.category) %></p>
  <p><strong>Equipment:</strong> <%= @exercise.equipment %></p>
  <p><strong>Sets:</strong> <%= @exercise.sets %></p>
  <p><strong>Reps:</strong> <%= @exercise.reps %></p>
  <p><strong>Instructions:</strong> <%= @exercise.instructions %></p>
</div>

<h2>Used In These Workouts</h2>

<% if @workouts.any? %>
  <ul class="simple-list">
    <% @workouts.each do |workout| %>
      <li><%= link_to workout.name, workout_path(workout) %></li>
    <% end %>
  </ul>
<% else %>
  <div class="list-box">
    <p>This exercise is not used in any workout yet.</p>
  </div>
<% end %>